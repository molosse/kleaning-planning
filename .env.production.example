# KLEANING — VARIABLES D'ENVIRONNEMENT (PRODUCTION)
# Copier ce fichier en .env sur le serveur puis remplacer chaque valeur.

# Clé JWT obligatoire — minimum 32 caractères.
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_UN_SECRET_LONG_ALEATOIRE

# Optionnel pour l'initialisation du compte admin via scripts/setup.js
ADMIN_USERNAME=administrateur
ADMIN_PASSWORD=REMPLACER_PAR_UN_MOT_DE_PASSE_FORT

# Google Calendar — Service Account
GOOGLE_PROJECT_ID=REMPLACER_PAR_LE_PROJECT_ID
GOOGLE_PRIVATE_KEY_ID=REMPLACER_PAR_LE_PRIVATE_KEY_ID
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREMPLACER_PAR_LA_CLE_PRIVEE_SUR_UNE_SEULE_LIGNE\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=REMPLACER_PAR_LE_CLIENT_EMAIL
GOOGLE_CLIENT_ID=REMPLACER_PAR_LE_CLIENT_ID
GOOGLE_CALENDAR_ID=REMPLACER_PAR_LE_CALENDAR_ID

# Serveur
PORT=3001
NODE_ENV=production