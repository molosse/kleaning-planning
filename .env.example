# ══════════════════════════════════════════════════════
# KLEANING — VARIABLES D'ENVIRONNEMENT
# Copiez ce fichier en .env et remplissez chaque valeur
# NE JAMAIS mettre .env sur Git
# ══════════════════════════════════════════════════════

# Clé secrète JWT — générer avec :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_CLE_64_CHARS_ALEATOIRE

# Identifiant admin (sera créé au 1er lancement via node scripts/setup.js)
ADMIN_USERNAME=jihad
ADMIN_PASSWORD=VOTRE_MOT_DE_PASSE_ADMIN

# Google Calendar — Service Account
GOOGLE_PROJECT_ID=kleaning-planning
GOOGLE_PRIVATE_KEY_ID=VOTRE_KEY_ID
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nVOTRE_CLE_PRIVEE\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=kleaning@kleaning-planning.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID
GOOGLE_CALENDAR_ID=ali.alaouiaziz@gmail.com

# Serveur
PORT=3001
NODE_ENV=production
